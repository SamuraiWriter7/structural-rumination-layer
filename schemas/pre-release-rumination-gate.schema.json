{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/pre-release-rumination-gate.schema.json",
  "title": "Pre-release Rumination Gate",
  "description": "A schema for representing pre-release rumination gate evidence and release readiness decisions.",
  "type": "object",
  "required": [
    "gate_id",
    "version",
    "gate_type",
    "target_release",
    "scope",
    "inputs",
    "validation_evidence",
    "gate_checks",
    "gate_decision",
    "human_review"
  ],
  "properties": {
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "gate_type": {
      "type": "string",
      "enum": [
        "pre_release"
      ]
    },
    "target_release": {
      "type": "object",
      "required": [
        "release_version",
        "tag_name",
        "status"
      ],
      "properties": {
        "release_version": {
          "type": "string",
          "minLength": 1
        },
        "tag_name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "candidate",
            "blocked",
            "released"
          ]
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "repository",
        "branch",
        "release_boundary"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "release_boundary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": [
        "rumination_records",
        "recurrence_rules_registry",
        "executable_checks",
        "multi_wing_links",
        "agent_hooks"
      ],
      "properties": {
        "rumination_records": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recurrence_rules_registry": {
          "type": "string",
          "minLength": 1
        },
        "executable_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "script",
              "status"
            ],
            "properties": {
              "script": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "not_started",
                  "passed",
                  "failed",
                  "manual_review_required"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "multi_wing_links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agent_hooks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "validation_evidence": {
      "type": "object",
      "required": [
        "summary",
        "commands"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "gate_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "status",
          "required",
          "evidence"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "warning",
              "manual_review_required"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "gate_decision": {
      "type": "object",
      "required": [
        "decision",
        "reason",
        "next_step"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "allow_candidate_tag",
            "warn",
            "request_human_review",
            "block_release"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "next_step": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "human_review": {
      "type": "object",
      "required": [
        "required",
        "reason",
        "reviewer_role"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "reviewer_role": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
